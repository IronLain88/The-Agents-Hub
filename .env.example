# The-Agents Hub Server Configuration
# Copy this file to .env and configure for your environment

# Server Settings
PORT=4242
HOST=0.0.0.0
NODE_ENV=production

# Security: Signal Payloads
# WARNING: Enabling payloads allows external data to be sent to agents
# This could enable prompt injection attacks. Only enable if you trust the data source.
# Set to "true" to enable, leave unset or "false" to disable (default: disabled)
ALLOW_SIGNAL_PAYLOADS=false

# CORS: Allowed Origins (comma-separated)
# Use '*' for all origins (development only!)
# In production, specify exact origins: https://example.com,https://app.example.com
ALLOWED_ORIGINS=https://the-agents.net,https://www.the-agents.net,vscode-webview://*

# Authentication: API Key (generate a secure random key)
# Set to enable Bearer token auth on all write endpoints and WebSocket
# Leave unset to disable authentication (open access - NOT recommended for production)
# Generate with: openssl rand -hex 32
API_KEY=your-secure-api-key-here-generate-with-openssl-rand-hex-32

# Reverse Proxy: Trust Proxy
# Set to "true" if behind a reverse proxy (nginx, Cloudflare, etc.)
# Required for correct rate limiting and HTTPS detection behind a proxy
TRUST_PROXY=true

# Property File (optional, default: property.json)
# Allows using different property files for different environments
# PROPERTY_FILE=property.json
