# The-Agents Hub Server Configuration
# Production Environment

# Server Settings
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Security: Signal Payloads
# Disabled by default for security
ALLOW_SIGNAL_PAYLOADS=false

# CORS: Allowed Origins
ALLOWED_ORIGINS=https://the-agents.net,https://www.the-agents.net

# Authentication: API Key (keep this secret!)
API_KEY=8147aaa5bb2399d5a4d064e1c3d85d1b02d48d98a5e58b2d1931f6212f1b0963

# Reverse Proxy: Trust Proxy
# Enable if behind nginx, Cloudflare, etc.
TRUST_PROXY=true

# Property File (optional)
# PROPERTY_FILE=property.json
